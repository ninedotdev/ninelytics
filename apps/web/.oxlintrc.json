{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "plugins": ["react", "typescript"],
  "rules": {
    "no-undef": "error",
    "no-unused-vars": "off"
  },
  "ignorePatterns": [
    "dist",
    ".tanstack",
    "node_modules",
    "src/routeTree.gen.ts"
  ]
}
