DATABASE_URL=""
NEXTAUTH_URL=""
NEXTAUTH_SECRET=""
JWT_SECRET=""
NEXT_PUBLIC_APP_URL=""
REDIS_URL=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
MAXMIND_LICENSE_KEY=""
MAXMIND_DB_PATH="/var/data/GeoLite2-City.mmdb"
# Google OAuth Providers for allow users to sync Search Console and GA4
GOOGLE_API_CLIENT_ID=""
GOOGLE_API_CLIENT_SECRET=""
# OAuth Providers (optional - configure as needed)
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"
# GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"

# ─── Seed (optional — used by `pnpm db:seed`) ───
# SEED_ADMIN_EMAIL="admin@localhost"
# SEED_ADMIN_PASSWORD="changeme"
# SEED_ADMIN_NAME="Admin"

# ─── Multi-Tenant Mode ───
# Set to "true" to enable SaaS mode (public signup, organizations, billing) this isnt full ready yet
# Default: "false" (personal/self-hosted mode — no public signup, admin invites users)
IS_MULTI_TENANT="false"

# ─── Uptime Notifications (all optional) ───
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="alerts@yourdomain.com"
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# Stripe (required only if IS_MULTI_TENANT=true)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PRICE_ID_PRO=""
# STRIPE_PRICE_ID_ENTERPRISE=""